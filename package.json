{
  "name": "voice-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.electron.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "concurrently \"npm run dev\" \"cross-env NODE_ENV=development electron .\"",
    "desktop:build": "npm run build && cross-env NODE_ENV=production electron ."
